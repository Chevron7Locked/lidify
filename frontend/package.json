{
  "name": "lidify-frontend",
  "version": "1.0.0",
  "description": "Lidify web and mobile frontend",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chevron7Locked/lidify.git"
  },
  "private": true,
  "scripts": {
    "dev": "next dev -p 3030",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3030",
    "lint": "eslint",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android",
    "mobile": "npm run cap:sync && npm run cap:run",
    "mobile:dev": "npx cap run android --live-reload --host=0.0.0.0 --port=3030",
    "build:android": "npm run build && NODE_ENV=production npx cap sync android",
    "build:apk:debug": "npm run build:android && cd android && gradlew assembleDebug",
    "build:apk:release": "npm run build:android && cd android && gradlew assembleRelease"
  },
  "dependencies": {
    "@anuradev/capacitor-background-mode": "^7.2.1",
    "@capacitor-community/keep-awake": "^7.1.0",
    "@capacitor-community/media": "^8.0.1",
    "@capacitor/android": "^7.4.4",
    "@capacitor/app": "^7.0.2",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/local-notifications": "^7.0.0",
    "@capacitor/preferences": "^7.0.2",
    "@capacitor/splash-screen": "^7.0.3",
    "@capacitor/status-bar": "^7.0.3",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@types/howler": "^2.2.12",
    "capacitor-music-controls-plugin": "^6.1.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "howler": "^2.2.4",
    "lucide-react": "^0.552.0",
    "next": "^16.0.8",
    "qrcode.react": "^4.2.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
